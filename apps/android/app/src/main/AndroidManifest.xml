<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!--
      POST_NOTIFICATIONS is the Android 13+ (API 33+) runtime permission for
      showing notifications. Declared here so the system knows we might ask;
      we request it at push-registration time (not app launch) via
      MainActivity.requestPushRegistration(). On API < 33 this permission is
      automatically granted and the runtime request is skipped.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <application
        android:label="@string/app_name"
        android:theme="@style/Theme.Conduit"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:allowBackup="false"
        android:usesCleartextTraffic="true">
        <meta-data
            android:name="io.sentry.auto-init"
            android:value="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|keyboardHidden|uiMode"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="conduit" />
            </intent-filter>
            <!--
              Agent OAuth callback (`apps/.../auth/OAuthClient.kt`).
              Chrome Custom Tabs hands control back via this filter
              when the provider redirects to
              `conduit://oauth/<provider>/callback?code=...`. The
              `host="oauth"` constraint makes the disambiguation in
              `SessionStore.handleOAuthCallback` explicit at the
              manifest level — a paired URL like
              `conduit://my-host?token=...` doesn't match and falls
              through to the existing filter above.
            -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="conduit" android:host="oauth" />
            </intent-filter>
        </activity>

        <!--
          UnifiedPush receiver (WS-P.3 primary path).

          The UnifiedPush android-connector library dispatches:
            • org.unifiedpush.android.connector.NOTIFY         → onMessage
            • org.unifiedpush.android.connector.NEW_ENDPOINT   → onNewEndpoint
            • org.unifiedpush.android.connector.UNREGISTERED   → onUnregistered

          android:exported="true" is required so the distributor app (ntfy,
          Sunup, …) can deliver messages even when Conduit is in the
          background. The receiver validates that every inbound intent carries
          the UnifiedPush instance / token that we registered, so exported=true
          does not open an arbitrary delivery surface.
        -->
        <receiver
            android:name=".push.ConduitUnifiedPushReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="org.unifiedpush.android.connector.NOTIFY" />
                <action android:name="org.unifiedpush.android.connector.NEW_ENDPOINT" />
                <action android:name="org.unifiedpush.android.connector.UNREGISTERED" />
            </intent-filter>
        </receiver>

        <!--
          FCM service (WS-P.3 fallback path).

          ConduitFcmService handles two FCM callbacks:
            • onMessageReceived — delivers foreground push messages and shows
              the local notification + session deep-link (background messages
              are auto-displayed by the FCM SDK from the notification block,
              with data extras passed to the tap intent).
            • onNewToken        — re-registers the new token with the broker
              when FCM rotates the device token.

          android:exported="false": the FCM system component dispatches to this
          service via the SDK's internal intent mechanism; no external callers
          should be able to address it directly.
        -->
        <service
            android:name=".push.ConduitFcmService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>
</manifest>
